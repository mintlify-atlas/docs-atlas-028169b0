  "keyFeatures": [
    "Real-time attendance tracking with check-in/out, break management, and automatic session classification",
    "Role-based access control (Admin, HR, Manager, Team Lead, Employee, Intern)",
    "Project governance with manager approval workflows and task lifecycle management",
    "Leave, WFH, and half-day request submission and approval flows",
    "Time tracking via live timers and manual log entries with complexity scoring",
    "Role-specific analytics dashboards (Admin, Manager, Employee) with KPI cards and trend charts",
    "Background job processing via Celery + Redis for alerts, email notifications, and metric aggregation",
    "WebSocket-based real-time presence and notifications",
    "WebRTC-powered in-app voice/video calls with optional recording",
    "Secure JWT authentication with refresh token rotation and rate limiting"
  ],
